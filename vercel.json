{
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/stock-pwa/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://stockbtp-api.onrender.com/api/$1"
    },
    {
      "source": "/((?!api).*)",
      "destination": "dist/public"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}