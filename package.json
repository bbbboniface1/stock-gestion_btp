{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.includes('pnpm')){console.error('Use pnpm instead');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "pnpm -r --filter \"./artifacts/**\" --if-present run test",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:migrate": "pnpm --filter @workspace/db run migrate",
    "db:seed": "pnpm --filter @workspace/db run seed",
    "db:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-db.ps1"
  },
  "private": true,
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.1",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}