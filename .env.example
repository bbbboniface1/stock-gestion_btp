# Copier ce fichier en .env et remplir les valeurs pour le développement local
# NE PAS committer .env dans git !

# Base de données Supabase (Connection Pooler, port 6543)
SUPABASE_DATABASE_URL=postgresql://postgres.VOTRE_PROJECT_REF:VOTRE_MOT_DE_PASSE@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Secret pour la signature des tokens d'authentification (générer une valeur aléatoire longue)
SESSION_SECRET=changez-moi-avec-une-valeur-aleatoire-longue

# Port de l'API (optionnel, défaut: 8080)
PORT=8080

# Commandes utiles :
# pnpm db:push   — appliquer le schéma Drizzle sur Supabase
# pnpm db:seed   — créer les comptes de test et données démo
# pnpm test      — lancer tous les tests
